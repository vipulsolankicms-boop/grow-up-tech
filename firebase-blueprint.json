{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact form inquiry from a potential student or client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the person inquiring."
        },
        "phone": {
          "type": "string",
          "description": "Phone number for contact."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address for contact."
        },
        "type": {
          "type": "string",
          "enum": [
            "Course Inquiry (MicroC@re)",
            "Technical Service (Grow Up Tech)",
            "Business AMC Support",
            "CCTV Installation",
            "Other"
          ],
          "description": "The type of inquiry."
        },
        "message": {
          "type": "string",
          "description": "The detailed message or question."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the inquiry was created."
        }
      },
      "required": ["name", "phone", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of all inquiries received through the contact form."
    }
  }
}
